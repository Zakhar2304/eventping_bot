# Telegram (from @BotFather)
BOT_TOKEN=

# Google Cloud OAuth (Web application client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local fallback only. In cloud, PUBLIC_BASE_URL / platform URL is used.
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
# Set after deploy, e.g. https://eventping-bot.up.railway.app
PUBLIC_BASE_URL=
OAUTH_HOST=0.0.0.0
OAUTH_PORT=8080

DEFAULT_TIMEZONE=Europe/Kyiv
DEFAULT_REMINDER_MINUTES=30

DB_BACKEND=supabase
DATABASE_PATH=data/eventping.db

# https://xxxx.supabase.co
SUPABASE_URL=
# Secret key sb_secret_... (backend only)
SUPABASE_KEY=
